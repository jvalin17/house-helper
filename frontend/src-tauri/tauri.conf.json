{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Panini",
  "version": "0.2.0",
  "identifier": "com.superpowerlab.panini",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Panini",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/panini-backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/jvalin17/house-helper/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ3RUMyNDIwQjA1MjQzREQKUldUZFExS3dJQ1RzUndkb3AzYnBWZWwvMGZMeXk1K0NxTm9PYjNMUzlCZjFlUDVuUDBPd1NDb3UK"
    }
  }
}

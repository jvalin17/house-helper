# House Helper — Environment Variables
# Copy this file to .env and fill in your keys

# Required for AI features (resume generation, LLM matching)
# Get one from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional — alternative to Claude
# OPENAI_API_KEY=

# Optional — enables job search via JSearch (LinkedIn, Indeed, Glassdoor)
# Free tier: 200 requests/month
# Get one from: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# RAPIDAPI_KEY=
